{
  "name": "royal-desi-crew-backend",
  "version": "1.0.0",
  "description": "Backend API for Royal Desi Crew",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run admin\"",
    "backend": "node src/server.js",
    "backend:dev": "nodemon src/server.js",
    "admin": "cd admin && npm start",
    "admin:dev": "cd admin && npm start",
    "build": "echo 'No build required for Node.js'",
    "seed": "node scripts/seedDatabase.js",
    "test": "node scripts/testAdminPortal.js"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.33.0",
    "concurrently": "^8.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "resend": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
  "engines": {
    "node": "24.x"
  }
}
